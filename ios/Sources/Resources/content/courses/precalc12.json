                "y-axis",
                "line y=x",
                "origin"
              ],
              "id": "precalc12_u1_l1_2"
            },
            {
              "type": "math",
              "question": "If f(x)=x^2 and g(x)=f(x)+4, what is g(2)?",
              "answer": "8",
              "id": "precalc12_u1_l1_3"
            },
            {
              "type": "mathChoice",
              "question": "y = 2f(x) is a vertical...",
