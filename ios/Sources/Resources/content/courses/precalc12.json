                "P(0)",
                "P(1)",
                "a"
              ],
              "id": "precalc12_u2_l1_1"
            },
            {
              "type": "mathChoice",
              "question": "By the Factor Theorem, (x-a) is a factor of P(x) if...",
              "answer": "P(a) = 0",
              "choices": [
                "P(a) = 0",
                "P(0) = a",
                "P(a) = 1",
                "a = 0"
              ],
              "id": "precalc12_u2_l1_2"
            },
            {
              "type": "math",
              "question": "Factor: x^2 - 9 =",
              "answer": "(x-3)(x+3)",
              "id": "precalc12_u2_l1_3"
            },
            {
              "type": "math",
              "question": "Find the remainder when x^2+3x+2 is divided by (x-1)",
              "answer": "6",
              "id": "precalc12_u2_l1_4"
            }
          ]
        },
        {
          "id": "u2l2",
          "title": "Graphing Polynomials",
