                "x-axis",
                "y-axis",
                "line y=x",
                "origin"
              ],
              "id": "precalc12_u1_l1_1"
            },
            {
              "type": "mathChoice",
              "question": "y = f(-x) reflects f(x) over the...",
              "answer": "y-axis",
