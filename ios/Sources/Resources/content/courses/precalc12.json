            },
            {
              "type": "mathChoice",
              "question": "The graph of f^-1(x) is the reflection of f(x) over...",
              "answer": "y = x",
              "choices": [
                "y = x",
                "x-axis",
                "y-axis",
                "origin"
              ],
              "id": "precalc12_u1_l2_1"
            },
            {
              "type": "math",
              "question": "Find the inverse of f(x) = 2x: f^-1(x) =",
              "answer": "x/2",
              "id": "precalc12_u1_l2_2"
            },
            {
              "type": "mathChoice",
              "question": "For f^-1 to exist as a function, f must be...",
              "answer": "one-to-one",
              "choices": [
                "one-to-one",
                "even",
                "odd",
                "continuous"
              ],
              "id": "precalc12_u1_l2_3"
            }
          ]
        }
      ]
